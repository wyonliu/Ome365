# ═══════════════════════════════════════════════════════════════
# Ome365 — .gitignore（敏感数据防线 · 严格版）
# 原则：所有"个人/公司/访谈/录音"数据一律排除；只推工程代码 + sample
# ═══════════════════════════════════════════════════════════════

# ── Personal vault data（用户私有，绝不推）──
/Journal/
/Notes/
/Decisions/
/Contacts/
/Projects/
/AI-Logs/
/Templates/
/Memory/
/000-365-PLAN.md
/000-DASHBOARD.md

# ── Sensitive work data（公司/访谈/候选人，绝不推）──
/Longfor/
/Hiring/
/Life/
/Insights/
/TicNote/
/ai-tmp/
/面试*.md
/interview-*.md

# ── Sensitive root files ──
/agent-plan.md
/agent-mem-evo-need.png
/arch.png
/screen-shot-*.png
/screenshot-*.png
/ome-api-requirements.md
/Untitled*.canvas

# ── App runtime data（每用户独立）──
.app/settings.json
.app/categories.json
.app/contact_categories.json
.app/special_days.json
.app/task_repeats.json
.app/claude_session.json
.app/growth.json
.app/reminders.json
.app/media/
.app/cache/

# ── Cockpit live config（含真实人名/组织/战略，用户私有 · 仅保留 .sample.json）──
.app/cockpit_config.json

# ── Share registry live（含真实分享文档映射 · 仅保留 .sample.json）──
.app/share_registry.json

# ── Tenant config live（含真实租户品牌/分类/提示 · 仅保留 .sample.json）──
.app/tenant_config.json

# ── TicNote export archived versions（保留最新 ticnote_export.py/ticnote_clean.py/ticnote_rename.py）──
.app/ticnote_export_0414.py
.app/ticnote_export_0415.py
.app/ticnote_export_new.py
.app/ticnote_download_0410.py
.app/UPGRADE_V8.md
.app/UPGRADE_V8_FULL.md
.app/screen-shot-v8-updates.png

# ── Secrets ──
.env
.env.local
*.key
*.pem

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
venv/
.venv/

# ── Node ──
node_modules/

# ── OS ──
.DS_Store
Thumbs.db

# ── IDE ──
.vscode/
.idea/
*.swp
.cursor/
.claude/
.obsidian/
