#!/bin/bash
# ════════════════════════════════════════════════════════════
# Pre-commit 守门员 · 阻止隐私数据 / 运行时配置被意外 commit
# 安装：git config core.hooksPath .githooks
# ════════════════════════════════════════════════════════════

set -e

staged=$(git diff --cached --name-only)
[ -z "$staged" ] && exit 0

# ── 1. 禁止 staging 的路径（目录 / 精确文件）──
BLOCKED_PATHS=(
  "Journal/" "Notes/" "Decisions/" "Contacts/" "Projects/" "AI-Logs/"
  "Templates/" "Memory/" "Longfor/" "Hiring/" "Life/" "Insights/"
  "TicNote/" "ai-tmp/"
  ".app/cockpit_config.json"
  ".app/media/" ".app/cache/" ".app/settings.json"
  ".env"
)
for p in "${BLOCKED_PATHS[@]}"; do
  # 目录结尾 "foo/" → 前缀匹配；普通文件 → 精确匹配（避免 .env 误杀 .env.example）
  if [[ "$p" == */ ]]; then
    match_pat="^${p}"
  else
    match_pat="^${p}$"
  fi
  if echo "$staged" | grep -qE "$match_pat"; then
    printf '✗ pre-commit: 禁止提交 [%s] —— 含隐私或运行时数据\n' "$p"
    echo '  如确需修改，请更新 .gitignore 或 sample 文件'
    exit 1
  fi
done

# ── 2. 内容层扫描：疑似真实密钥（长度≥20 字符后缀） ──
# 排除 .githooks/（hook 自己的 pattern 会自匹配）
scan_files=$(echo "$staged" | grep -v '^\.githooks/' || true)
if [ -n "$scan_files" ]; then
  leak_patterns=(
    'sk-or-v1-[A-Za-z0-9]{32,}'
    'sk-ant-api[0-9]{2}-[A-Za-z0-9_-]{32,}'
  )
  for pat in "${leak_patterns[@]}"; do
    if git diff --cached -- $scan_files | grep -qE "$pat"; then
      echo "✗ pre-commit: 检测到疑似密钥 ($pat)"
      exit 1
    fi
  done
fi

# ── 3. 业务名扫描：禁止具体企业 / 产品 / 内部俗称写进 public 代码 ──
# 原则：船长口头举例 ≠ 可写进 public 仓的素材。统一换 acme/globex/<tenant-slug> 占位。
# blocklist 从 .githooks/business_name_blocklist.txt 读（每行一个，# 开头为注释）
# 只扫代码/docs/测试/config 路径；memory 文件、sample 数据、历史迁移代码不扫。
BIZ_BLOCKLIST_FILE=".githooks/business_name_blocklist.txt"
if [ -f "$BIZ_BLOCKLIST_FILE" ] && [ -n "$scan_files" ]; then
  biz_words=$(grep -vE '^\s*(#|$)' "$BIZ_BLOCKLIST_FILE" | tr '\n' '|' | sed 's/|$//')
  if [ -n "$biz_words" ]; then
    # 扫描范围限定：.app/ docs/ scripts/ README.md 顶层 md
    biz_scan_files=$(echo "$scan_files" | grep -E '^(\.app/|docs/|scripts/|[^/]+\.md$|tenant_config\.sample\.json$)' || true)
    # 排除历史迁移代码 / migrate 脚本 / sample 示例 / 本 hook 自身
    biz_scan_files=$(echo "$biz_scan_files" | grep -vE '^(scripts/migrate_to_multiuser\.py|\.app/tenant_config\.sample\.json)$' || true)
    if [ -n "$biz_scan_files" ]; then
      hit=$(git diff --cached -- $biz_scan_files | grep -iE "^\+.*($biz_words)" || true)
      if [ -n "$hit" ]; then
        echo "✗ pre-commit: 检测到业务名泄露（代码 vs 数据分离原则）"
        echo "$hit" | head -10
        echo ""
        echo "  规则：具体企业/产品/内部俗称不能写进 .app/ docs/ scripts/ 的 public 代码。"
        echo "  替换成占位：acme / globex / example.com / <tenant-slug> / Alice / Bob"
        echo "  blocklist: $BIZ_BLOCKLIST_FILE （需新增词直接编辑）"
        exit 1
      fi
    fi
  fi
fi

exit 0
