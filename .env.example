# ══════════════════════════════════════════════════════
# Ome365 环境变量示例
# 使用：复制为 .env （gitignored）并按需填值
# ══════════════════════════════════════════════════════

# ── 运行时 ──
# 端口（默认 3650）
# OME365_PORT=3650

# 数据 vault 根目录（默认是项目根）
# OME365_VAULT=/path/to/your/vault

# 安装元数据根（tenants/ sessions.db / magic_tokens.db 的家；默认 ~/.ome365）
# OME365_HOME=/var/lib/ome365

# 强制 legacy 单用户（tenants/ 存在时也忽略，兜底用）
# OME365_COMPAT_LEGACY=1

# 上传文件大小上限（MB，默认 200）
# MAX_UPLOAD_MB=200


# ── 认证 ──
# 覆盖 tenant_config.auth.provider；值：none | basic | magic_link | oidc | wecom
# OME365_AUTH_PROVIDER=basic

# Cookie Secure 标志 —— 默认 on（生产 HTTPS）。
# 本地 http://localhost 开发时必须设 0，否则浏览器不会回传 cookie 导致登录无效。
# OME365_COOKIE_SECURE=0

# 登录限流（防暴力破解）—— 默认 5 次 / 5 分钟窗口 / 锁 15 分钟
# OME365_LOGIN_MAX_ATTEMPTS=5
# OME365_LOGIN_WINDOW_SECONDS=300
# OME365_LOGIN_LOCKOUT_SECONDS=900

# demo 模式兜底密码（basic provider 未显式配 users 时，自动造 demo 用户）
# OME365_DEMO_PASSWORD=change-me

# magic_link provider 的 SMTP 密码
# OME365_SMTP_PASSWORD=your-smtp-app-password

# OIDC / 企微（Phase 2c）
# OME365_OIDC_SECRET=
# OME365_WECOM_SECRET=


# ── AI 对话（设置页也可配，此处仅为 CI/部署场景）──
# 模式：api | ollama | none
# AI_MODE=api

# DeepSeek（推荐，中文优 + 性价比高）
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# OpenRouter（多模型切换，需代理）
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Ollama（本地纯离线）
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1


# ── Optional: 语音转写 ──
# WHISPER_MODEL=base     # tiny/base/small/medium/large-v3
# WHISPER_DEVICE=cpu     # cpu/cuda


# ── Optional: 驾舱租户 ──
# 不填则跑 sample 驾舱（占位 demo）
# 填真值方法：复制 .app/cockpit_config.sample.json → .app/cockpit_config.json 并按自家组织架构填
